# --- Database ---
# Async SQLAlchemy URL (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://scheduler:scheduler@localhost:5432/scheduler
# Test database (docker compose service db_test on :5433)
TEST_DATABASE_URL=postgresql+asyncpg://scheduler:scheduler@localhost:5433/scheduler_test

# --- Auth ---
JWT_SECRET=change-me-in-production-please
ACCESS_TOKEN_TTL_MIN=60

# --- Worker ---
WORKER_CONCURRENCY=8
WORKER_POLL_INTERVAL_S=1.0
WORKER_CLAIM_BATCH_SIZE=10
DRAIN_TIMEOUT_S=30

# --- Heartbeats / reaper ---
HEARTBEAT_INTERVAL_S=5
HEARTBEAT_TIMEOUT_S=30

# --- Scheduler ---
SCHEDULER_POLL_INTERVAL_S=1.0
